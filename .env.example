# ==========================================
# Meme Sniper Bot 配置文件 (.env)
# 部署时请将此文件重命名为 .env 并填入你的真实数据
# ==========================================

# --- Grok / XAI 配置 ---
# 从 x.ai 获取你的 API KEY
GROK_API_KEY=xai-your_grok_api_key_here

# --- Telegram Bot 配置 ---
# 从 BotFather 获取的 Token
TG_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
# 接收推送消息的 Chat ID (可以是你个人的ID或者群组ID)
TG_CHAT_ID=your_chat_id_here
#--- 飞书 Webhook 配置 ---

#在飞书群机器人设置中获取的 Webhook URL

FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/1880f8ff-07df-465a-a09e-3e8f2b46e4ea

# --- 扫盘引擎配置 ---
# 每次扫盘的时间间隔 (秒)，默认 30 秒
SCAN_INTERVAL_SECONDS=30
# 目标链配置 (CT_501: Solana, 56: BSC)
TARGET_CHAIN_ID=CT_501