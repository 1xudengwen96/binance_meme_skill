# ==========================================
# Meme Sniper Bot 配置文件 (.env)
# 部署时请将此文件重命名为 .env 并填入你的真实数据
# ==========================================

# --- Grok / XAI 配置 ---
# 从 x.ai 获取你的 API KEY
#grok模型选择grok-4-1-fast-reasoning，grok-4-1-fast-non-reasoning
GROK_MODEL=grok-4-1-fast-reasoning
GROK_API_KEY=xai-your_grok_api_key_here

# --- Telegram Bot 配置 ---
# 从 BotFather 获取的 Token
TG_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
# 接收推送消息的 Chat ID (可以是你个人的ID或者群组ID)
TG_CHAT_ID=your_chat_id_here
#--- 飞书 Webhook 配置 ---

#在飞书群机器人设置中获取的 Webhook URL

FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/1880f8ff-07df-465a-a09e-3e8f2b46e4ea

# --- 扫盘引擎配置 ---
# 每次扫盘的时间间隔 (秒)，默认 30 秒
SCAN_INTERVAL_SECONDS=30
# 目标链配置 (CT_501: Solana, 56: BSC)
TARGET_CHAIN_ID=CT_501

# ==========================================
# 自动交易配置 (Auto-Trading)
# ==========================================
# Solana 钱包私钥 (Base58格式，Phantom导出的那串字符)
# ⚠️警告：绝不能泄露此私钥！强烈建议使用放有少量资金的新钱包！
SOL_PRIVATE_KEY=your_base58_private_key_here

# 每次探测到 S 级金狗，自动买入的 SOL 数量 (如 0.1)
BUY_AMOUNT_SOL=0.1

# Solana 主网 RPC 节点 (可用官方默认，建议用 QuickNode/Alchemy 提升速度)
SOL_RPC_URL=https://api.mainnet-beta.solana.com